# Nightcrawler — Configuration
# Copy to .env and adjust as needed. All values have sensible defaults.

# Web server
NC_HOST=0.0.0.0
NC_PORT=8090

# Capture output directory
NC_OUTPUT_DIR=./output

# Observer location (latitude/longitude in degrees, elevation in meters)
NC_OBSERVER_LAT=48.2
NC_OBSERVER_LON=16.4
NC_OBSERVER_ELEVATION=200.0

# Timeouts (seconds)
NC_SLEW_TIMEOUT=120.0
NC_SETTLE_DELAY=3.0       # pause after slew before capture (mount vibration dampening)
NC_SETTLE_TIMEOUT=30.0
NC_CAPTURE_TIMEOUT_EXTRA=60.0

# INDI server (telescope/camera control)
NC_INDI_HOST=localhost
NC_INDI_PORT=7624
